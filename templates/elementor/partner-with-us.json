          "elements": [
            {
              "id": "pwu_hero_img",
              "elType": "widget",
              "widgetType": "image",
              "settings": {
                "image": {"url":"{ASSETS}/contact/group.png","id":""},
                "image_size": "full",
                "align": "center",
                "border_radius": {"unit":"px","top":"18","right":"18","bottom":"18","left":"18","isLinked":true}
              }
