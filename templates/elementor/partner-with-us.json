  "content": [
    {
      "id": "pwu_hero",
      "elType": "section",
      "settings": {
        "structure": "20",
        "background_background": "classic",
        "background_color": "#fce7f0",
        "padding": {"unit":"px","top":"80","right":"32","bottom":"96","left":"32","isLinked":false},
        "content_width": {"unit":"px","size":1320},
        "gap": "extended"
      },
      "elements": [
        {
          "id": "pwu_hero_col1",
          "elType": "column",
          "settings": {"_column_size": 50, "content_position": "center"},
          "elements": [
            {
              "id": "pwu_hero_h1",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "PARTNER WITH US",
                "header_size": "h1",
                "title_color": "#6a1753",
                "typography_typography": "custom",
                "typography_font_family": "Cormorant Garamond",
                "typography_font_size": {"unit":"px","size":64},
                "typography_font_weight": "400",
                "typography_letter_spacing": {"unit":"px","size":-1.3},
                "typography_line_height": {"unit":"em","size":1.0},
                "typography_text_transform": "uppercase"
              }
            },
            {
              "id": "pwu_hero_body",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Join us in empowering immigrant and refugee women in Calgary. Together we open doors to employment, community, and lasting impact.</p>",
                "text_color": "#1a1a1a",
                "typography_typography": "custom",
                "typography_font_family": "Inter",
                "typography_font_size": {"unit":"px","size":18},
                "typography_font_weight": "400",
                "typography_line_height": {"unit":"em","size":1.6},
                "_margin": {"unit":"px","top":"20","right":"0","bottom":"28","left":"0","isLinked":false}
              }
            },
            {
              "id": "pwu_hero_btn",
              "elType": "widget",
              "widgetType": "button",
              "settings": {
                "text": "JOIN NOW ›",
                "link": {"url":"#partner-contact","is_external":"","nofollow":""},
                "align": "left",
                "size": "md",
                "background_color": "#f68b3c",
                "button_text_color": "#ffffff",
                "hover_background_color": "#e07d2e",
                "typography_typography": "custom",
                "typography_font_family": "Cormorant Garamond",
                "typography_font_size": {"unit":"px","size":15},
                "typography_font_weight": "400",
                "typography_letter_spacing": {"unit":"px","size":1.5},
                "typography_text_transform": "uppercase",
                "border_radius": {"unit":"px","top":"8","right":"8","bottom":"8","left":"8","isLinked":true},
                "text_padding": {"unit":"px","top":"14","right":"28","bottom":"14","left":"28","isLinked":false}
              }
            }
          ]
        },
        {
          "id": "pwu_hero_col2",
          "elType": "column",
